{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "baseUrl": ".",
    "composite": true,
    "module": "esnext",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@hooks/*": ["./hooks/*"]
    }
  }
}
